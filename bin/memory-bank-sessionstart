#!/usr/bin/env bash
# Claude Code SessionStart フック。
# プロジェクトに Memory Bank（.work/skills/memory-bank/ など）があれば、
# 「タスク開始前に memory-bank スキルの手順で読む」よう文脈注入する。
# 発火は必ずログに残す（動作確認用）。無ければ何もしない（no-op）。
#
# stdin: SessionStart の JSON（読み飛ばしてよい）。
# cwd: $CLAUDE_PROJECT_DIR（無ければ $PWD）。
set -euo pipefail

cat >/dev/null 2>&1 || true   # stdin を消費（壊れても無視）

# このスクリプトと同階層の補助ツール（lint-doc-refs 等）を解決する。
script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

proj="${CLAUDE_PROJECT_DIR:-$PWD}"
log="${MB_HOOK_LOG:-$HOME/.claude/memory-bank-hook.log}"
log_keep="${MB_HOOK_LOG_KEEP:-500}"   # ログは直近この行数だけ残す

# ログ追記。肥大化しないよう直近 $log_keep 行に切り詰める。
append_log() {
  mkdir -p "$(dirname "$log")"
  echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$log"
  tail -n "$log_keep" "$log" > "$log.tmp" && mv "$log.tmp" "$log"
}

mb=""
for d in "$proj/.work/skills/memory-bank" "$proj/memory-bank"; do
  [ -d "$d" ] && { mb="$d"; break; }
done

# Memory Bank が無ければ no-op（全プロジェクトで鳴るのでログは残さない。
# 切り分け時は MB_HOOK_DEBUG=1 で no-op もログする）。
if [ -z "$mb" ]; then
  [ "${MB_HOOK_DEBUG:-0}" = "1" ] && append_log "SessionStart proj=$proj mb=none"
  exit 0
fi

# dir があっても 6 コアが揃っていなければ Memory Bank として機能しない。
# 「dir はあるのに中身が無い／欠けている」状態を黙って見逃さず、警告して
# initialize を促す（存在チェックを [ -d ] だけで済ませない＝充足を検証する）。
core="projectbrief productContext activeContext systemPatterns techContext progress"
missing=""
for f in $core; do
  [ -f "$mb/$f.md" ] || missing="${missing}${missing:+, }$f.md"
done

if [ -n "$missing" ]; then
  append_log "SessionStart proj=$proj mb=$mb INCOMPLETE missing=$missing"
  msg="警告: このプロジェクトの Memory Bank（${mb}）はコアファイルが欠けており、Memory Bank として機能しません（不足: ${missing}）。memory-bank スキルの手順で「initialize memory bank」を実行し、6 コア（projectbrief / productContext / activeContext / systemPatterns / techContext / progress）を揃えてから着手してください。中身を伴わない空ディレクトリだけが残っている場合はそれ自体が異常です。"
else
  append_log "SessionStart proj=$proj mb=$mb"
  msg="このプロジェクトには Memory Bank があります（${mb}）。タスク開始前に memory-bank スキルの手順に従い、コアファイル（projectbrief / productContext / activeContext / systemPatterns / techContext / progress）を読んでから着手してください。"
fi

# A: 前セッションから持ち越した未コミット WIP を表面化する（非ブロッキング）。
# funnel（interrupt 受信箱）をすり抜けて「始めたまま落ちた」中途半端な編集・未記録の
# 要望は、未コミット変更として残る。種類を問わず毎セッション開始時に必ず可視化し、
# 「思い出したら気づく」ではなく「毎回機械的に気づく」状態にする（記憶に依存しない検知）。
if git -C "$proj" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  dirty="$(git -C "$proj" status --porcelain 2>/dev/null || true)"
  if [ -n "$dirty" ]; then
    n=$(printf '%s\n' "$dirty" | grep -c . || true)
    listed=$(printf '%s\n' "$dirty" | head -n 10)
    append_log "SessionStart proj=$proj WIP=$n"
    msg="${msg}"$'\n\n'"注意: 前セッションからの未コミット変更が ${n} 件あります（funnel をすり抜けた中途半端な作業／未記録の要望の可能性）。着手前に内容を確認し、完了させてコミットするか、要望なら interrupt へ記録してください:"$'\n'"${listed}"
  fi
fi

# B: スキル文書の宙吊り前方参照を lint（skills/ を持つ repo＝dotfiles 等でのみ実行）。
# 「下記『X』」が指す節が書かれていない、というクラスのバグを決定論的に捕まえる。
# skills/ が無い repo ではゼロコスト。失敗しても本来の通知は止めない（best-effort）。
if [ -d "$proj/skills" ] && command -v python3 >/dev/null 2>&1 && [ -x "$script_dir/lint-doc-refs" ]; then
  refout="$(python3 "$script_dir/lint-doc-refs" "$proj"/skills/*/SKILL.md 2>/dev/null || true)"
  if [ -n "$refout" ]; then
    append_log "SessionStart proj=$proj DANGLING_REFS"
    msg="${msg}"$'\n\n'"注意: スキル文書に宙吊りの前方参照があります（予告した節が未実装の可能性）:"$'\n'"${refout}"
  fi
fi

# C: supervisor 起動時のワーカー roll-up。
# SessionStart はプロセス単位の起動イベントで、起動時の CLAUDE_PROJECT_DIR にしか効かない
# ＝1 プロセス内で worker に「コンテキストスイッチ」しても再発火しない。運用は
# 「1 repo = 1 セッション」（worker 作業は worker を cwd にした別セッションで起動）を前提とし、
# その代わり supervisor 起動時に配下 worker の状態（未コミット WIP / Memory Bank 充足）を
# 一覧表示して dispatch 判断を助ける。supervisor 宣言（CLAUDE.md の workers_dir）がある repo のみ。
workers_dir=""
if [ -f "$proj/CLAUDE.md" ]; then
  workers_dir="$(grep -oE 'workers_dir:[[:space:]]*[A-Za-z0-9._/-]+' "$proj/CLAUDE.md" 2>/dev/null | head -n1 | sed -E 's/.*workers_dir:[[:space:]]*//' || true)"
fi
if [ -n "$workers_dir" ] && [ -d "$proj/$workers_dir" ]; then
  roll=""
  for w in "$proj/$workers_dir"/*; do
    [ -e "$w" ] || continue
    wname="$(basename "$w")"
    if git -C "$w" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      wn="$(git -C "$w" status --porcelain 2>/dev/null | grep -c . || true)"
    else
      wn="?"
    fi
    mbstat="MB:ok"
    if [ -d "$w/.work/skills/memory-bank" ]; then
      for f in $core; do [ -f "$w/.work/skills/memory-bank/$f.md" ] || { mbstat="MB:不完全"; break; }; done
    else
      mbstat="MB:なし"
    fi
    roll="${roll}"$'\n'"  - ${wname}: 未コミット ${wn} 件 / ${mbstat}"
  done
  if [ -n "$roll" ]; then
    append_log "SessionStart proj=$proj WORKERS rollup"
    msg="${msg}"$'\n\n'"ワーカー状況（supervisor 起動時 roll-up。worker 作業は worker を cwd にした別セッションで）:""${roll}"
  fi
fi

# jq に依存せず、JSON 文字列として最低限のエスケープ（\ と " と改行）を行う。
esc=${msg//\\/\\\\}
esc=${esc//\"/\\\"}
esc=${esc//$'\n'/\\n}
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"}}\n' "$esc"
