#!/usr/bin/env bash
# 議事録 Markdown を生成する。
# - 保存先: <dotfiles>/.cache/docs/meetings/（.cache はローカル限定・非コミット）
# - ファイル名: 現在時刻を 15 分単位に丸めた yyyymmddhhmm.md
# - 既に存在していたらエラー（上書きしない）
# - 任意の引数はタイトルとして見出しに付く: new-meeting "週次MTG"
# 丸め単位は環境変数 MEETING_STEP_MIN で変更可（既定 15）。
set -euo pipefail

DOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MEET_DIR="$DOT/.cache/docs/meetings"
STEP_MIN="${MEETING_STEP_MIN:-15}"

mkdir -p "$MEET_DIR"

# 現在の epoch 秒を STEP_MIN 分単位に四捨五入（時・日の繰り上がりは date が処理）
now="$(date +%s)"
step=$(( STEP_MIN * 60 ))
rounded=$(( (now + step / 2) / step * step ))

stamp="$(date -d "@$rounded" +%Y%m%d%H%M)"
human="$(date -d "@$rounded" '+%Y-%m-%d %H:%M')"
file="$MEET_DIR/$stamp.md"

if [ -e "$file" ]; then
  echo "error: 既に存在します: $file" >&2
  exit 1
fi

title="${1:-}"

cat > "$file" <<EOF
# 議事録 $human${title:+ — $title}

- 日時: $human
- 参加者:

## アジェンダ

## 議事

## 決定事項

## ToDo / 宿題
- [ ]
EOF

echo "$file"
