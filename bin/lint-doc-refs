#!/usr/bin/env python3
"""ドキュメント内の「宙吊り前方参照」を検出する lint。

「下記/上記/前述/後述『X』」のように **同一ファイル内の節を指す参照** について、
X を含む見出し（`# …`）がそのファイルに無ければ「宙吊り参照」として報告する。
（＝「予告した節が書かれていない」というクラスのバグを決定論的に捕まえる。
  例: 本リポジトリで `memory clean` が description/起動時チェックから「下記『メモリー
  クリーン』」と参照されながら本体の節が未実装のまま数日埋もれた事故の再発防止。）

`[[name]]` リンクは **意図的に未実装でもよい**（後で書く印）ため対象にしない。
ここで見るのは「下記/上記」など同一ドキュメント内の自己参照だけ。

使い方: lint-doc-refs FILE [FILE ...]
終了コード: 宙吊りが 1 件以上で 1、無ければ 0、引数なしで 2。
"""

import re
import sys

# 同一ドキュメント内の節を指す参照（「下記『X』」等）。X を捕獲する。
REF = re.compile(r"(?:下記|上記|前述|後述)の?「([^」]+)」")
# 参照先になりうるもの＝見出し（`# …`）と、節見出しの代わりに使う太字ラベル（`**…**`）。
# 本ドキュメント群は blockquote 内の `> **ラベル**` を小見出し代わりに使うため両方を対象にする。
HEADING = re.compile(r"^#{1,6}\s+(.*?)\s*$")
BOLD = re.compile(r"\*\*([^*]+?)\*\*")


def check(path):
    """path 内の宙吊り参照を [(行番号, 参照名), ...] で返す。"""
    try:
        with open(path, encoding="utf-8") as f:
            lines = f.readlines()
    except OSError as e:
        print(f"{path}: 読み取り失敗: {e}", file=sys.stderr)
        return []
    targets = []
    for ln in lines:
        if m := HEADING.match(ln):
            targets.append(m.group(1))
        targets.extend(BOLD.findall(ln))
    findings = []
    for i, ln in enumerate(lines, 1):
        for name in REF.findall(ln):
            # 参照名がいずれかの見出し／太字ラベルに含まれていれば解決済み（部分一致で許容。
            # 見出しは「メモリークリーン（memory clean ＝ …）」のように補足が付くため）。
            if not any(name in t for t in targets):
                findings.append((i, name))
    return findings


def main(argv):
    files = argv[1:]
    if not files:
        print("usage: lint-doc-refs FILE [FILE ...]", file=sys.stderr)
        return 2
    total = 0
    for path in files:
        for line_no, name in check(path):
            total += 1
            print(f"{path}:{line_no}: 宙吊り参照「{name}」に対応する見出しが無い")
    if total:
        print(
            f"\n宙吊り参照 {total} 件。予告した節を書くか、参照を修正してください。",
            file=sys.stderr,
        )
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
