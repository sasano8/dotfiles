{
  "model": "opus[1m]",
  "theme": "dark-ansi",
  "tui": "fullscreen",
  "permissions": {
    "allow": [
      "Read(.work/skills/flow-memory-bank/**)",
      "Edit(.work/skills/flow-memory-bank/**)",
      "Write(.work/skills/flow-memory-bank/**)",
      "Read(.work/skills/memory-bank/**)",
      "Edit(.work/skills/memory-bank/**)",
      "Write(.work/skills/memory-bank/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/projects/dotfiles/bin/worker-boundary-guard",
            "timeout": 10,
            "statusMessage": "編集境界を確認中..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/projects/dotfiles/bin/memory-bank-sessionstart",
            "timeout": 10,
            "statusMessage": "Memory Bank を確認中..."
          },
          {
            "type": "command",
            "command": "$HOME/projects/dotfiles/bin/skills-check-sessionstart",
            "timeout": 10,
            "statusMessage": "スキルのリンクを確認中..."
          }
        ]
      }
    ]
  }
}
